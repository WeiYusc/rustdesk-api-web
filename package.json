{
  "name": "rustdesk-api-web",
  "version": "1.0.0",
  "description": "Modern admin frontend for RustDesk API (Vue3 + TypeScript + Naive UI)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "build:only": "vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src --ext .ts,.vue --fix",
    "lint:check": "eslint src --ext .ts,.vue",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,css,scss,json}\""
  },
  "dependencies": {
    "@vicons/ionicons5": "^0.13.0",
    "axios": "^1.7.9",
    "clipboard": "^2.0.11",
    "cropperjs": "^1.6.0",
    "marked": "^15.0.0",
    "nprogress": "^0.2.0",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-i18n": "^11.1.0",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.0",
    "@types/nprogress": "^0.2.3",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@unocss/preset-icons": "^0.65.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/tsconfig": "^0.7.0",
    "eslint": "^9.17.0",
    "eslint-plugin-vue": "^9.32.0",
    "globals": "^17.7.0",
    "naive-ui": "^2.41.0",
    "prettier": "^3.4.2",
    "sass": "^1.83.0",
    "typescript": "~5.7.2",
    "unocss": "^66.7.3",
    "unplugin-auto-import": "^0.19.0",
    "unplugin-vue-components": "^0.28.0",
    "vfonts": "^0.0.3",
    "vite": "^8.1.0",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.2.0"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20"
  }
}
